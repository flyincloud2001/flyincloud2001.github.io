{
  "name": "personal-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node -e \"require('fs').copyFileSync('index.template.html','index.html')\" && vite build && node -e \"const fs=require('fs');fs.copyFileSync('dist/index.html','dist/404.html')\"",
    "deploy": "npm run build && node -e \"const fs=require('fs'),p=require('path');fs.copyFileSync('dist/index.html','index.html');fs.copyFileSync('dist/404.html','404.html');['robots.txt','sitemap.xml'].forEach(f=>{if(fs.existsSync(p.join('dist',f)))fs.copyFileSync(p.join('dist',f),f)});fs.readdirSync('dist/assets').forEach(f=>{fs.copyFileSync(p.join('dist/assets',f),p.join('assets',f))})\"",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@supabase/supabase-js": "^2.106.1",
    "gsap": "^3.15.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^5.4.0"
  }
}
